rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SHUTTLEQUEUE SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset enforces a strict ownership and participant-based access model while facilitating
     * discovery through public read access for shared resources like Courts and Queues. It relies
     * heavily on denormalized authorization data (e.g., `userId` and `playerIds` fields) to ensure
     * that security decisions are atomic, high-performance, and independent of complex document lookups.
     *
     * Data Structure:
     * - /userProfiles/{userId}: Private user profile and nested match history (Path-based ownership).
     * - /courts/{courtId}: Publicly readable directory of badminton courts.
     * - /queues/{queueId}: Publicly readable queue status with user-specific entries.
     * - /matches/{matchId}: Shared match documents accessible by participants.
     * - /bookings/{bookingId}: Private court reservations accessible by the booking user and admins.
     *
     * Key Security Decisions:
     * 1. Path-Based Authorization: User profiles and history are secured by matching the UID to the path.
     * 2. Field-Based Authorization: Shared documents (Matches, Bookings, QueueEntries) use internal
     *    UID fields to verify ownership or participation without requiring parent document reads.
     * 3. Role-Based Access: Administrative actions (managing courts/queues) are secured by checking
     *    for the existence of a document in a dedicated /admin_roles collection.
     * 4. Public Discovery: Courts and active Queue status are readable by everyone to allow
     *    seamless onboarding and real-time updates.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Verifies a user is the owner and the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the authenticated user has an entry in the administrative roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- User Profile Rules ---

    /**
     * @description Rules for the UserProfile collection. Access is strictly path-based.
     * @path /userProfiles/{userId}
     * @allow User 'abc' to (get) their own profile /userProfiles/abc.
     * @deny User 'xyz' to (list) the /userProfiles collection.
     * @principle Restricts access to a user's own data tree via path-based ownership.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for user-specific match history entries. Nested under the profile.
       * @path /userProfiles/{userId}/matchHistory/{matchHistoryEntryId}
       * @allow User 'abc' to (create) a history entry at /userProfiles/abc/matchHistory/123.
       * @deny User 'xyz' to (get) an entry at /userProfiles/abc/matchHistory/123.
       * @principle Structural segregation of private user-specific logs.
       */
      match /matchHistory/{matchHistoryEntryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    // --- Court and Queue Rules (Public Read / Admin Write) ---

    /**
     * @description Rules for Court information. Publicly readable for discovery.
     * @path /courts/{courtId}
     * @allow Anonymous user to (get) a court document.
     * @deny Authenticated non-admin user to (update) a court's hourlyRate.
     * @principle Public Read with Admin-Only Writes.
     */
    match /courts/{courtId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for Queues. Publicly readable for real-time status.
     * @path /queues/{queueId}
     * @allow Any user to (list) all queues to see wait times.
     * @deny Authenticated non-admin user to (delete) a queue.
     * @principle Public Read with Admin-Only Writes.
     */
    match /queues/{queueId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      /**
       * @description Rules for entries within a specific queue.
       * @path /queues/{queueId}/queueEntries/{queueEntryId}
       * @allow User 'abc' to (update) their own entry status to 'Left'.
       * @deny User 'abc' to (create) an entry for user 'xyz'.
       * @principle Resource-specific ownership using denormalized userId.
       */
      match /queueEntries/{queueEntryId} {
        allow get, list: if isSignedIn();
        allow create: if isOwner(request.resource.data.userId);
        allow update: if isExistingOwner(resource.data.userId) || isAdmin();
        allow delete: if isExistingOwner(resource.data.userId) || isAdmin();
      }
    }

    // --- Match and Booking Rules (Collaborative & User-Owned) ---

    /**
     * @description Rules for Match documents. Access based on participant list or completion status.
     * @path /matches/{matchId}
     * @allow Participant 'abc' to (get) a match where 'abc' is in playerIds.
     * @allow Anyone to (get) a match if status is 'Completed'.
     * @deny User 'xyz' to (update) a match they are not participating in.
     * @principle Shared access via denormalized member UIDs.
     */
    match /matches/{matchId} {
      allow get, list: if (isSignedIn() && request.auth.uid in resource.data.playerIds) || resource.data.status == 'Completed';
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.playerIds;
      allow update: if (isSignedIn() && request.auth.uid in resource.data.playerIds) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for direct Court Bookings.
     * @path /bookings/{bookingId}
     * @allow User 'abc' to (create) a booking for themselves.
     * @deny User 'abc' to (get) a booking belonging to user 'xyz'.
     * @principle Owner-only writes with Admin oversight for resource management.
     */
    match /bookings/{bookingId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn(); // Queries must still filter by userId or courtId
      allow create: if isOwner(request.resource.data.userId);
      allow update: if (isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId) || isAdmin();
      allow delete: if isExistingOwner(resource.data.userId) || isAdmin();
    }

    // --- Admin Roles (System Collection) ---

    /**
     * @description Internal collection used to define administrative privileges.
     * @path /admin_roles/{adminId}
     * @principle DBAC - Existence of document determines role.
     */
    match /admin_roles/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Roles must be managed via Cloud Functions or Console.
    }
  }
}