/**
 * TheBreakfastClub - Simplified Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a fully permissive model for a local-only 
 * admin prototype. Authentication is ignored to facilitate rapid 
 * development and testing in a controlled environment.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permit all reads and writes for local prototyping
    match /{document=**} {
      allow read, write: if true;
    }
  }
}