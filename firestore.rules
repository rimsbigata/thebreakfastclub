rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SHUTTLEQUEUE SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset enforces a strict ownership and participant-based access model.
     * It supports a global directory for user profiles and a session-based 
     * isolation model for active queueing.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Verifies a user is the owner and the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the authenticated user has an entry in the administrative roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- User Profile Rules ---

    match /userProfiles/{userId} {
      allow get: if isSignedIn(); // Allow visibility for session rosters
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Club-Wide Settings ---

    match /clubSettings/{settingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // --- Session-Based Queueing (Main System) ---

    match /sessions/{sessionId} {
      // Admins manage sessions. Signed-in users can find sessions by code.
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /players/{userId} {
        // Everyone in the club can see who is in a session
        allow get, list: if isSignedIn();
        // Users can join a session, and admins can add players to the roster
        allow create: if isOwner(userId) || isAdmin();
        // Users can update their own status, admins can manage anyone
        allow update, delete: if isOwner(userId) || isAdmin();
      }

      match /courts/{courtId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /matches/{matchId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /fees/{feeId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /paymentMethods/{methodId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /settings/{settingId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    // --- Admin Roles (System Collection) ---

    match /admin_roles/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Roles must be managed via Console.
    }

    // --- Boost Schedules ---

    match /boost_schedules/{scheduleId} {
      allow get, list: if isSignedIn(); // All authenticated users can see upcoming boosts
      allow create: if isAdmin() && request.resource.data.sessionCode is string && request.resource.data.sessionCode.length == 6;
      allow update, delete: if isAdmin(); // Only admins can manage boost schedules
    }

    // --- Push Tokens ---
    match /pushTokens/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- Collection Group Rules for Leaderboards ---
    match /{path=**}/matches/{matchId} {
      allow read: if isSignedIn();
    }
  }
}
