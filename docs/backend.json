
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile, including personal details, skill levels, and preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "name": {
          "type": "string",
          "description": "The display name of the player."
        },
        "email": {
          "type": "string",
          "description": "The player's contact email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["player", "admin"],
          "description": "The user's access level within the club."
        },
        "skillLevel": {
          "type": "integer",
          "description": "The player's numeric skill level (1-7)."
        },
        "playingPreferences": {
          "type": "array",
          "description": "A list of the player's preferred match types or play styles.",
          "items": {
            "type": "string"
          }
        },
        "profileImageUrl": {
          "type": "string",
          "description": "URL to the player's profile picture.",
          "format": "uri"
        },
        "dateJoined": {
          "type": "string",
          "description": "Timestamp when the user registered for the app.",
          "format": "date-time"
        },
        "lastActive": {
          "type": "string",
          "description": "Timestamp of the user's last activity in the app.",
          "format": "date-time"
        },
        "favoriteCourtIds": {
          "type": "array",
          "description": "References to Courts that this user has marked as favorites.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role",
        "skillLevel",
        "dateJoined"
      ]
    },
    "Court": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Court",
      "type": "object",
      "description": "Represents a badminton court available for queuing or booking.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Court entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the court (e.g., 'Court 1')."
        },
        "status": {
          "type": "string",
          "enum": ["available", "occupied"],
          "description": "Current status of the court."
        },
        "currentMatchId": {
          "type": "string",
          "description": "ID of the match currently being played on this court."
        }
      },
      "required": [
        "id",
        "name",
        "status"
      ]
    },
    "QueueSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QueueSession",
      "type": "object",
      "description": "Represents an active badminton queueing session.",
      "properties": {
        "id": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"]
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "code", "status", "createdBy", "createdAt"]
    },
    "Match": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Match",
      "type": "object",
      "description": "Represents a badminton match.",
      "properties": {
        "id": {
          "type": "string"
        },
        "courtId": {
          "type": "string"
        },
        "teamA": {
          "type": "array",
          "items": { "type": "string" }
        },
        "teamB": {
          "type": "array",
          "items": { "type": "string" }
        },
        "teamAScore": {
          "type": "integer"
        },
        "teamBScore": {
          "type": "integer"
        },
        "status": {
          "type": "string",
          "enum": ["ongoing", "completed", "cancelled"]
        },
        "isCompleted": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "teamA", "teamB", "status", "isCompleted", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles.",
          "params": [
            {
              "name": "userId",
              "description": "Firebase Auth UID."
            }
          ]
        }
      },
      {
        "path": "/sessions/{sessionId}",
        "definition": {
          "entityName": "QueueSession",
          "schema": {
            "$ref": "#/backend/entities/QueueSession"
          },
          "description": "Active queueing sessions."
        }
      },
      {
        "path": "/sessions/{sessionId}/players/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Players joined to a specific session."
        }
      },
      {
        "path": "/sessions/{sessionId}/courts/{courtId}",
        "definition": {
          "entityName": "Court",
          "schema": {
            "$ref": "#/backend/entities/Court"
          },
          "description": "Courts active in a session."
        }
      },
      {
        "path": "/sessions/{sessionId}/matches/{matchId}",
        "definition": {
          "entityName": "Match",
          "schema": {
            "$ref": "#/backend/entities/Match"
          },
          "description": "Matches played in a session."
        }
      },
      {
        "path": "/admin_roles/{adminId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "type": "object",
            "properties": {
              "uid": { "type": "string" }
            }
          },
          "description": "DBAC for system administrators."
        }
      }
    ]
  }
}
