
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Information about a user, including their role.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["player", "admin"] },
        "skillLevel": { "type": "number" },
        "playStyle": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "role"]
    },
    "QueueSession": {
      "title": "Queue Session",
      "type": "object",
      "description": "An active badminton session with a specific code.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "status"]
    },
    "SessionPlayer": {
      "title": "Session Player",
      "type": "object",
      "description": "Mapping of a user to an active queue session.",
      "properties": {
        "userId": { "type": "string" },
        "sessionId": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "playing", "resting"] },
        "joinedAt": { "type": "string", "format": "date-time" },
        "lastAvailableAt": { "type": "number" }
      },
      "required": ["userId", "sessionId", "status"]
    },
    "Court": {
      "title": "Court",
      "type": "object",
      "description": "Represents a badminton court.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "occupied"] },
        "currentMatchId": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Match": {
      "title": "Match",
      "type": "object",
      "description": "A 2v2 doubles match.",
      "properties": {
        "id": { "type": "string" },
        "teamA": { "type": "array", "items": { "type": "string" } },
        "teamB": { "type": "array", "items": { "type": "string" } },
        "courtId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isCompleted": { "type": "boolean" }
      },
      "required": ["id", "teamA", "teamB", "timestamp", "isCompleted"]
    }
  },
  "auth": {
    "providers": ["email", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "Global user profiles" },
    "/sessions/{sessionId}": { "schema": { "$ref": "#/entities/QueueSession" }, "description": "Queue sessions" },
    "/sessions/{sessionId}/players/{userId}": { "schema": { "$ref": "#/entities/SessionPlayer" }, "description": "Players in a session" },
    "/sessions/{sessionId}/courts/{courtId}": { "schema": { "$ref": "#/entities/Court" }, "description": "Courts in a session" },
    "/sessions/{sessionId}/matches/{matchId}": { "schema": { "$ref": "#/entities/Match" }, "description": "Matches in a session" }
  }
}
