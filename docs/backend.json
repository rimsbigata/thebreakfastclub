
{
  "entities": {
    "Court": {
      "title": "Court",
      "type": "object",
      "description": "Represents a badminton court.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "occupied"] },
        "currentMatchId": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Player": {
      "title": "Player",
      "type": "object",
      "description": "Represents a player with skill and history.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "skillLevel": { "type": "number", "description": "1 to 7" },
        "gamesPlayed": { "type": "number" },
        "partnerHistory": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["available", "playing", "resting"] },
        "improvementScore": { "type": "number" }
      },
      "required": ["id", "name", "skillLevel", "gamesPlayed", "partnerHistory", "status", "improvementScore"]
    },
    "Match": {
      "title": "Match",
      "type": "object",
      "description": "A 2v2 doubles match.",
      "properties": {
        "id": { "type": "string" },
        "teamA": { "type": "array", "items": { "type": "string" } },
        "teamB": { "type": "array", "items": { "type": "string" } },
        "courtId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isCompleted": { "type": "boolean" }
      },
      "required": ["id", "teamA", "teamB", "courtId", "timestamp", "isCompleted"]
    },
    "Fee": {
      "title": "Fee",
      "type": "object",
      "description": "Daily fee records.",
      "properties": {
        "id": { "type": "string", "description": "YYYY-MM-DD" },
        "shuttleFee": { "type": "number" },
        "courtFee": { "type": "number" },
        "entranceFee": { "type": "number" },
        "qrCodeUrl": { "type": "string" },
        "payments": { "type": "object", "additionalProperties": { "type": "boolean" } }
      },
      "required": ["id", "shuttleFee", "courtFee", "entranceFee", "payments"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/courts/{courtId}": { "schema": { "$ref": "#/entities/Court" }, "description": "Courts list" },
    "/players/{playerId}": { "schema": { "$ref": "#/entities/Player" }, "description": "Players profiles" },
    "/matches/{matchId}": { "schema": { "$ref": "#/entities/Match" }, "description": "Match history" },
    "/fees/{dateId}": { "schema": { "$ref": "#/entities/Fee" }, "description": "Daily financial records" }
  }
}
